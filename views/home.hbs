    {{!RESET button section}}
    <div class="reset-section">
      <h2>Database Reset Functionality</h2>
      <p>Click the button below to reset the database to its original sample data state:</p>
      <a href="/reset-database" onclick="return confirm('WARNING: This will delete all changes and restore the database to its original same data. Are you sure?')">
        <button>
          RESET Database
        </button>
      </a>

      <h3>Demo: Test the RESET function</h3>
      <p>To verify the RESET works:</p>
      <ol>
        <li>Click the "Delete Demo Loan" link below to remove one loan record</li>
        <li>Visit the <a href="/loans">Loans page</a> to confirm the loan is gone</li>
        <li>Click the RESET button above</li>
        <li>Return to the <a href="/loans">Loans page</a> - the loan should be restored!</li>
      </ol>
      <a href="/delete-demo-loan" onclick="return confirm('Delete the demo loan to test RESET functionality?')">
        <button>
          Delete Demo Loan
        </button>
      </a>
    </div>

