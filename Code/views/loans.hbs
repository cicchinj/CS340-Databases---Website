{{#if deletedDemo}}
<div class="alert alert-warning">
    Demo loan has been deleted. Click RESET on the home page to restore it.
</div>
{{/if}}

<h1>Records of loan transactions</h1>

{{! READ table }}
<table>
    <thead>
        <tr>
            <th>Loan ID</th>
            <th>Copy ID</th>
            <th>Patron</th>            
            <th>Checkout Date</th>
            <th>Due Date</th>
            <th>Return Date</th>
            <th>Late Fee</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        {{#each loans}}
        <tr>
            <td>{{this.loanID}}</td>
            <td>{{this.copyID}}</td>
            <td>{{this.patronID}}</td>
            <td>{{this.checkoutDate}}</td>
            <td>{{this.dueDate}}</td>
            <td>{{this.returnDate}}</td>
            <td>${{this.lateFee}}</td>
            <td>{{this.status}}</td>
            <td>
                {{! DELETE form }}
                <form class="inlineForm" action="/loans/delete" method="POST">
                    <input type="hidden" name="loanID" value="{{this.loanID}}" />
                    <button type="submit" onclick="return confirm('Delete this loan?');">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

{{! CREATE form }}
<h2>Create New Loan</h2>
<form class="cuForm" id="create_loan_form" action="/loans/add" method="POST">

    <!-- Book Copy -->
    <label for="copyID">Book Copy: </label>
    <select name="copyID" id="copyID" required>
        <option value="" disabled selected>Select a Copy</option>
        {{#each loans}}
        <option value="{{this.copyID}}">{{this.title}} (ID: {{this.copyID}})</option>
        {{/each}}
    </select>

    <!-- Patron -->
    <label for="patronID">Patron: </label>
    <select name="patronID" id="patronID" required>
        <option value="" disabled selected>Select a Patron</option>
        {{#each loans}}
        <option value="{{this.patronID}}">{{this.patronID}}</option>
        {{/each}}
    </select>

    <!-- Checkout Date -->
    <label for="checkoutDate">Checkout Date: </label>
    <input type="date" name="checkoutDate" id="checkoutDate" required />

    <!-- Due Date -->
    <label for="dueDate">Due Date: </label>
    <input type="date" name="dueDate" id="dueDate" required />

    <!-- Status -->
    <label for="status">Status: </label>
    <select name="status" id="status" required>
        <option value="" disabled selected>Select Status</option>
        <option value="Active">Active</option>
        <option value="Returned">Returned</option>
        <option value="Overdue">Overdue</option>
        <option value="Lost">Lost</option>
    </select>

    <input type="submit" value="Create Loan" />
</form>

{{! UPDATE form }}
<h2>Update a Loan</h2>
<form class="cuForm" id="update_loan_form" action="/loans/update" method="POST">

    <!-- Loan to Update -->
    <label for="update_loan_id">Loan to Update: </label>
    <select name="loanID" id="update_loan_id" required>
        <option value="" disabled selected>Select a Loan</option>
        {{#each loans}}
        <option value="{{this.loanID}}">
            ID: {{this.loanID}} - Patron: {{this.patronID}}
        </option>
        {{/each}}
    </select>

    <!-- Return Date -->
    <label for="update_returnDate">Return Date: </label>
    <input type="date" name="returnDate" id="update_returnDate" />

    <!-- Late Fee ($)-->
    <label for="update_lateFee">Late Fee ($): </label>
    <input type="number" name="lateFee" id="update_lateFee" min="0" step="0.01" value="0" />

    <!-- Status -->
    <label for="update_status">Status: </label>
    <select name="status" id="update_status" required>
        <option value="" disabled selected>Select Status</option>
        <option value="Active">Active</option>
        <option value="Returned">Returned</option>
        <option value="Overdue">Overdue</option>
        <option value="Lost">Lost</option>
    </select>

    <input type="submit" value="Update Loan" />
</form>