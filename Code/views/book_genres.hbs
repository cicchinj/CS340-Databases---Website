<h1>Book-Genre Relationship</h1>

{{! READ table}}
<table>
    <thead>
        <tr>
            <th>Book ID</th>
            <th>Book Title</th>
            <th>Genre ID</th>
            <th>Genre Name</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        {{#each book_genres}}
        <tr>
            <td>{{this.bookID}}</td>
            <td>{{this.title}}</td>
            <td>{{this.genreID}}</td>
            <td>{{this.genreName}}</td>
            <td>
                {{! DELETE form}}
                <form class="inlineForm" action="/book_genres/delete" method="POST">
                    <input type="hidden" name="bookID" value="{{this.bookID}}" />
                    <input type="hidden" name="genreID" value="{{this.genreID}}" />
                    <button type="submit" onclick="return confirm('Delete this relationship?');">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

{{! CREATE form}}
<h2>Add Book-Genre Relationship</h2>
<form class="cuForm" id="create_book_genre_form" action="/book_genres/add" method="POST">
    <label for="bookID">Book: </label>
    <select name="bookID" id="bookID" required>
        <option value="" disabled selected>Select a Book</option>
        {{#each books}}
        <option value="{{this.bookID}}">{{this.title}}</option>
        {{/each}}
    </select>

    <label for="genreID">Genre: </label>
    <select name="genreID" id="genreID" required>
        <option value="" disabled selected>Select a Genre</option>
        {{#each genres}}
        <option value="{{this.genreID}}">{{this.genreName}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Add Relationship" />
</form>

{{! UPDATE form}}
<h2>Update Book-Genre Relationship</h2>
<form class="cuForm" id="update_book_genre_form" action="/book_genres/update" method="POST">
    <label for="update_book_id">Book: </label>
    <select name="bookID" id="update_book_id" required>
        <option value="" disabled selected>Select a Book</option>
        {{#each books}}
        <option value="{{this.bookID}}">{{this.title}}</option>
        {{/each}}
    </select>

    <label for="old_genre_id">Current Genre: </label>
    <select name="old_genreID" id="old_genre_id" required>
        <option value="" disabled selected>Select Current Genre</option>
        {{#each genres}}
        <option value="{{this.genreID}}">{{this.genreName}}</option>
        {{/each}}
    </select>

    <label for="new_genre_id">New Genre: </label>
    <select name="new_genreID" id="new_genre_id" required>
        <option value="" disabled selected>Select New Genre</option>
        {{#each genres}}
        <option value="{{this.genreID}}">{{this.genreName}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Update Relationship" />
</form>